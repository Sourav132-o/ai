import requests
import subprocess
import os
import re

# --- CONFIGURATION ---
OLLAMA_URL = "http://localhost:11434/api/generate"
MODEL = "llama3"

def query_ollama_for_tool(user_input):
    try:
        # AI-কে শুধু টুল চেনার কাজ দেওয়া হয়েছে, কমান্ড বদলানোর নয়
        system_logic = (
            "You are a search engine for Kali Linux tools. "
            "Do not modify the user's command. Do not add symbols like '|' or '-'. "
            "Output ONLY the exact command the user needs."
        )
        response = requests.post(OLLAMA_URL, json={
            'model': MODEL, 
            'prompt': f"{system_logic}\nTask: {user_input}", 
            'stream': False,
            'options': {'temperature': 0.0}
        }, timeout=120)
        
        res = response.json()['response'].strip()
        # AI যদি কোনো ব্যাখ্যা বা নোট দেয় সেগুলো ছেঁটে ফেলার লজিক
        res = re.sub(r'```[a-z]*\n|```', '', res)
        clean_res = res.split('\n')[0].strip().rstrip(' -.,|')
        return clean_res
    except:
        return None

def main():
    os.system('clear')
    print("="*65)
    print("   PENTEST-AI: TRANSPARENT BRIDGE MODE (NO AI AUTO-EDIT)  ")
    print("   STATUS: USER COMMANDS ARE ABSOLUTE | AI IS SEARCH ONLY ")
    print("="*65)
    
    while True:
        try:
            # সরাসরি ইনপুট নেওয়া
            user_input = input("\n[God Mode] > ").strip()
            if user_input.lower() in ['exit', 'quit']: break
            if not user_input: continue

            # AI থেকে সাজেস্ট করা কমান্ড আনা
            ai_suggestion = query_ollama_for_tool(user_input)
            
            # ডিসিশন লজিক: 
            # যদি তুমি সরাসরি পূর্ণ কমান্ড লেখো (যেমন: sudo arp-scan -l), সেটাই রান হবে।
            # যদি শুধু 'scan' লেখো, তবে AI যেটা সাজেস্ট করবে সেটা দেখাবে।
            final_cmd = user_input if len(user_input.split()) > 1 else ai_suggestion

            print(f"\n[!] READY TO RUN: {final_cmd}")
            
            confirm = input("Execute? (y/n): ").lower()
            if confirm == 'y':
                print("[*] Executing exactly as requested...\n")
                # তোমার দেওয়া কমান্ড হুবহু রান হবে
                subprocess.run(final_cmd, shell=True)
                
        except KeyboardInterrupt:
            break

if __name__ == "__main__":
    main()
