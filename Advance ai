# ==============================================
# CORE LOGIC & SMART FUNCTIONS
# ==============================================

def query_ollama(prompt):
    try:
        response = requests.post(OLLAMA_URL, json={'model': MODEL, 'prompt': prompt, 'stream': False}, timeout=180)
        return response.json()['response'].strip()
    except Exception as e:
        print(f"Ollama Error: {e}")
        return None

def smart_fixer(command):
    if "sherlock" in command and "-" in command and "--" not in command:
        command = command.replace("sherlock", "sherlock --")
    if "instaloader" in command and "--break-system-packages" not in command:
        command = f"{command} --break-system-packages"
    return command

def check_security(cmd, user_input):
    cmd_lower = cmd.lower()
    input_lower = user_input.lower()
    
    if 'sudo' in cmd_lower and 'extreme' not in input_lower:
        return False, "Sudo access requires 'extreme' flag."
    
    for pat in DANGEROUS_PATTERNS:
        if re.search(pat, cmd_lower):
            if 'force' not in input_lower:
                return False, f"Blocked Pattern: {pat}. Use 'FORCE' to bypass."
    
    return True, "Safe"

def execute_async(cmd, user_input):
    def run():
        print(f"\n[*] Target Acquired. Executing: {cmd}")
        try:
            process = subprocess.Popen(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
            full_output = ""
            for line in process.stdout:
                print(f"  > {line}", end="")
                full_output += line
            process.wait()
            
            # Save Activity Report
            log_file = os.path.join(REPORT_DIR, "activity_log.txt")
            with open(log_file, "a") as f:
                f.write(f"[{datetime.datetime.now()}]\nTask: {user_input}\nCommand: {cmd}\nOutput:\n{full_output}\n{'-'*80}\n")
        except Exception as e:
            print(f"[-] Runtime Error: {e}")

    threading.Thread(target=run).start()

